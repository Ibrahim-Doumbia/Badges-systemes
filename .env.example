# Serveur
PORT=3000
NODE_ENV=development

# Base de données PostgreSQL
DB_HOST=db
DB_PORT=5432
DB_NAME=badges_systeme
DB_USER=postgres
DB_PASSWORD=

# JWT
JWT_SECRET=
JWT_EXPIRES_IN=24h

# Mot de passe par défaut pour les nouveaux utilisateurs
DEFAULT_PASSWORD=

# URL de base de l'API (utilisée pour les QR codes si FRONTEND_URL n'est pas défini)
BASE_URL=http://localhost:3000

# URL du frontend (utilisée pour les liens QR code d'inscription des participants)
FRONTEND_URL=http://localhost:5173

# Email (SMTP)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=ton-email@gmail.com
MAIL_PASS=ton-mot-de-passe-application
MAIL_FROM=ton-email@gmail.com