{
  "info": {
    "name": "Badges Système API",
    "description": "Collection complète pour tester l'API de gestion d'événements et de badges QR Code.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000/api" },
    { "key": "token", "value": "" },
    { "key": "userId", "value": "" },
    { "key": "eventTypeId", "value": "" },
    { "key": "eventId", "value": "" },
    { "key": "dayId", "value": "" },
    { "key": "categoryId", "value": "" },
    { "key": "roleId", "value": "" },
    { "key": "teamMemberId", "value": "" },
    { "key": "participantId", "value": "" },
    { "key": "inscriptionId", "value": "" },
    { "key": "badgeId", "value": "" }
  ],
  "item": [
    {
      "name": "🔐 Authentification",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Token présent', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.data.token).to.be.a('string');",
                  "  pm.collectionVariables.set('token', body.data.token);",
                  "  console.log('Token enregistré :', body.data.token.substring(0,30) + '...');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"Password123!\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] }
          }
        },
        {
          "name": "Changer le mot de passe",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"oldPassword\": \"Password123!\",\n  \"newPassword\": \"NouveauMotDePasse1!\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/change-password", "host": ["{{baseUrl}}"], "path": ["auth", "change-password"] }
          }
        },
        {
          "name": "Mon profil (me)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Pas de mot de passe dans la réponse', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.data).to.not.have.property('password');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/auth/me", "host": ["{{baseUrl}}"], "path": ["auth", "me"] }
          }
        }
      ]
    },
